openapi: 3.0.3

info:
  title: Enterprise API Automation Framework
  description: REST Assured Automation using DummyJSON
  version: 1.0.0

servers:
  - url: https://dummyjson.com

paths:

  /users/{id}:
    get:
      summary: Get User
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer

      responses:
        '200':
          description: User Found

    put:
      summary: Update User
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer

      responses:
        '200':
          description: User Updated

    delete:
      summary: Delete User

      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer

      responses:
        '200':
          description: User Deleted

  /users/add:
    post:
      summary: Create User

      responses:
        '201':
          description: User Created

  /auth/login:
    post:
      summary: Login

      responses:
        '200':
          description: Login Successful